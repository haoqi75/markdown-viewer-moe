{
  "name": "markdown-viewer-moe",
  "version": "1.10.0",
  "description": "由AI生成的Moe Markdown查看器",
  "scripts": {
    "build": "run-s build:page build:tools",
    "build:page": "gulp build",
    "build:release": "run-s build:page && node script/release.js",
    "build:tools": "pnpm --filter moe-json-editor build:html && node script/copy-tools.js",
    "dev": "gulp",
    "dev:tools": "pnpm --filter moe-json-editor dev",
    "start": "gulp"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "clean-css": "^5.3.3",
    "del": "^7.1.0",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-htmlmin": "^5.0.1",
    "gulp-inline": "^0.1.3",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-uglify": "^3.0.2",
    "npm-run-all2": "^9.0.2",
    "uglify-js": "^3.19.3"
  }
}